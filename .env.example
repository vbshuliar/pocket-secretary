# App
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_CONNECT_TOKEN_TTL_SECONDS=900

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_REDIS_KEY_PREFIX=pocket-secretary

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback
GOOGLE_OAUTH_SCOPES="https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/gmail.compose https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/documents https://www.googleapis.com/auth/contacts.readonly"
GOOGLE_TOKEN_ENCRYPTION_KEY=

# Google Workspace defaults
GOOGLE_DEFAULT_CALENDAR_ID=primary

# Optional defaults
DEFAULT_TIMEZONE=Europe/London
EMAIL_WATCH_INTERVAL_MS=10000
